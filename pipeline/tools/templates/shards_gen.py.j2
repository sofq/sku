from __future__ import annotations

ALL_SHARDS: tuple[str, ...] = (
{% for s in shards %}
    "{{ s.shard }}",
{% endfor %}
)

_PROVIDER_OF: dict[str, str] = {
{% for s in shards %}
    "{{ s.shard }}": "{{ s.provider }}",
{% endfor %}
}


def provider_of(shard: str) -> str:
